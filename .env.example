# Supabase 프로젝트 설정 (Project Settings > API 에서 확인)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# 주의: VITE_UPSTAGE_API_KEY는 더 이상 프론트엔드에서 사용하지 않습니다.
# Upstage API 키는 이제 Supabase Edge Function의 시크릿으로만 저장합니다.
# (터미널에서: supabase secrets set UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxxxxxxxxxxxxx)
